  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f37954bd34ce354d8901857a59326aa, type: 3}
  m_Name: IntroSequence
  m_EditorClassIdentifier: 
  sequenceName: Intro
  completionFlag: 
  lines:
  - text: "- Resident Evil: Sisoft - \n\nby CorryWestSide"
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: 9 Marzo 2026
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: 'Mi chiamo Salvatore Leonardi, ma tutti mi chiamano Leon.

      Agente
      FBI.'
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: Questa mattina ho ricevuto un messaggio disperato
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: "\u201CPerdonami\u2026 ho fallito\u2026 nel luogo delle perdute speranze.\u201D"
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: "Sapevo che era in pericolo. Il mio amico\u2026 ha bisogno di me."
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: 'Quando varco la soglia della Sisoft s.r.l., qualcosa non va.

'
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: "Il silenzio \xE8 assordante. Le luci tremolano, "
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: "scricchiolano i pavimenti, e l\u2019aria \xE8 greve di ferro e morte."
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: "Qualcuno\u2026 o qualcosa\u2026 si nasconde tra queste mura."
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: "E io devo scoprire cosa \xE8 successo\u2026 prima che sia troppo tardi."
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 1
    lineDelay: 2
    typewriterSpeed: 0.05
  - text: 
    image: {fileID: 0}
    textSize: 20
    fadeSpeed: 0
    lineDelay: 0
    typewriterSpeed: 0.05
